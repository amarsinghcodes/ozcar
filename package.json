{
  "name": "ozcar",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-first ozcar audit extension package",
  "keywords": [
    "audit",
    "pi-extension",
    "pi-package",
    "security"
  ],
  "pi": {
    "extensions": [
      "./.pi/extensions/ozcar/index.ts"
    ],
    "prompts": [
      "./.pi/prompts"
    ],
    "skills": [
      "./.pi/skills"
    ]
  },
  "bin": {
    "ozcar": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.pi.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
